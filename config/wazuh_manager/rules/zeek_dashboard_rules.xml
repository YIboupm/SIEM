<group name="zeek,network,">
  <rule id="100300" level="5">
    <decoded_as>zeek-wazuh</decoded_as>
    <description>Zeek event ingested through zeek-wazuh bridge</description>
    <group>zeek,network,</group>
  </rule>

  <rule id="100301" level="7">
    <if_sid>100300</if_sid>
    <match> GET </match>
    <description>Zeek HTTP request observed</description>
    <group>zeek,http,network,</group>
  </rule>

  <rule id="100302" level="6">
    <if_sid>100300</if_sid>
    <match> 8080 </match>
    <description>Zeek connection to victim web port 8080</description>
    <group>zeek,network,web,</group>
  </rule>

  <rule id="100303" level="8">
    <if_sid>100301</if_sid>
    <match>curl/</match>
    <description>Zeek HTTP request uses curl user-agent</description>
    <group>zeek,http,suspicious-client,</group>
  </rule>
</group>
